# Build stage
FROM golang:1.25-alpine AS builder

ARG AGENT_PATH=./examples/echo-agent

WORKDIR /app

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source
COPY . .

# Build agent
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/agent ${AGENT_PATH}

# Runtime stage
FROM alpine:3.19

WORKDIR /app

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /bin/agent /bin/agent

ENTRYPOINT ["/bin/sh", "-c"]
CMD ["/bin/agent --server ${A2A_SERVER:-localhost:8080} --host ${AGENT_HOST:-localhost} --port ${AGENT_PORT:-50052}"]
